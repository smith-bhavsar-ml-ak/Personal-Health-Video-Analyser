# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL password (any secure string)
POSTGRES_PASSWORD=change_me_in_production

# App secret key — used for JWT signing (generate with: openssl rand -hex 32)
SECRET_KEY=change_me_in_production

# Groq API key — get free at console.groq.com → API Keys
# Provides hosted LLM inference (llama-3.1-8b-instant by default)
GROQ_API_KEY=gsk_your_key_here

# ── Optional ──────────────────────────────────────────────────────────────────

# LLM model to use (default: llama-3.1-8b-instant)
# Other Groq models: llama-3.3-70b-versatile, mixtral-8x7b-32768
LLM_MODEL=llama-3.1-8b-instant

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost

# Max video upload size in MB
MAX_VIDEO_SIZE_MB=200

# Rate limit for /analyze endpoint
ANALYZE_RATE_LIMIT=10/minute

# For separate-service Railway deployments: full backend URL passed to Flutter web build
# API_BASE=https://your-backend.railway.app/api/v1
