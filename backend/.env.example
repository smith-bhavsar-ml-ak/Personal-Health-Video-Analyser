# ── Required ──────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, dev only):
DATABASE_URL=sqlite+aiosqlite:///./data/phva.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/phva

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Ollama / LLM ─────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=30

# ── Video upload ──────────────────────────────────────────────────────────────
MAX_VIDEO_SIZE_MB=200

# ── Auth tokens ───────────────────────────────────────────────────────────────
# Token expiry in minutes (default: 10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080
